FROM maven:3.9.9-eclipse-temurin-21

WORKDIR /workspace/mozhi-backend

RUN apt-get update \
    && apt-get install -y entr --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

EXPOSE 8090

CMD ["sh", "-lc", "while true; do find . \\( -path './*/target' -o -path './.git' -o -path './.idea' \\) -prune -o \\( -name '*.java' -o -name '*.xml' -o -name '*.yml' -o -name '*.yaml' -o -name 'pom.xml' \\) -print | entr -rnz sh -lc 'mvn -q -pl mozhi-app -am package -Dmaven.test.skip=true && java -jar mozhi-app/target/mozhi-app-1.0.0-SNAPSHOT.jar --spring.profiles.active=dev'; sleep 2; done"]
